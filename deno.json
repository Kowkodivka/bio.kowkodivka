{
  "nodeModulesDir": "manual",
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check",
    "dev": "vite",
    "build": "vite build",
    "start": "vite serve"
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "exclude": [],
  "imports": {
    "@/": "./src/",
    "@solid-primitives/i18n": "npm:@solid-primitives/i18n@^2.2.1",
    "@solidjs/router": "npm:@solidjs/router@^0.16.1",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.2.2",
    "daisyui": "npm:daisyui@^5.5.19",
    "lucide-solid": "npm:lucide-solid@^1.7.0",
    "solid-devtools": "npm:solid-devtools@^0.34.5",
    "solid-js": "npm:solid-js@^1.9.12",
    "tailwindcss": "npm:tailwindcss@^4.2.2",
    "typescript": "npm:typescript@^6.0.2",
    "vite": "npm:vite@^8.0.3",
    "vite-plugin-solid": "npm:vite-plugin-solid@^2.11.11"
  },
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "preserve",
    "jsxImportSource": "solid-js",
    "types": [
      "vite/client"
    ]
  }
}
